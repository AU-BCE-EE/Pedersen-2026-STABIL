"S Scenario 3" = "#fdae6b"
)
ggplot(dfl, aes(x = x_plot, y = EF, fill = fill_id)) +
geom_col(width = 0.7) +
scale_fill_manual(values = cols) +
labs(y = "Ammonia emission (frac. TAN)") +
theme_bw() +
facet_grid( ~ new.ID, scales = "free_x") +
theme(legend.title = element_blank(), legend.position = 'bottom',
axis.ticks.x = element_blank(), axis.title.x = element_blank(), axis.text.x = element_text(angle = 90, vjust = 0.5, hjust = 1)) +
scale_x_discrete(labels = c('', 'Average', 'Low', 'High')) +
scale_fill_manual(values = cols, breaks = c("Unseparated", "L Scenario 1", "S Scenario 1"), labels = c("Unseparated", "Liquid fraction", "Solid fraction")) +
scale_y_continuous(expand = expansion(mult = c(0, 0.05)))
