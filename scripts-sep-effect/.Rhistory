# selecting relevant rows and trials
df <- df[, c('new.ID', 'treat', 'e.rel.130')]
df <- df[!(new.ID == 'Trial 7' | new.ID == 'Trial 8' | new.ID == 'Trial 9')]
df[, form := fcase(
treat == 'AD'   | treat == 'PS',   'raw',
treat == 'AD-L' | treat == 'PS-L', 'liquid',
treat == 'AD-F' | treat == 'PS-F', 'solid'
)]
dw <- dcast(
df,
new.ID ~ form,
value.var = c('e.rel.130')
)
w <- c(0.01, 0.05, 0.10, 0.15, 0.20, 0.25)
dw[paste0("Scenario ", seq_along(w))] <-
dw$liquid * (1 - w) + dw$solid * w
w <- c(0.01, 0.05, 0.10, 0.15, 0.20, 0.25)
weighted_matrix <- sapply(w, function(wi) {
dw$liquid * (1 - wi) + dw$solid * wi
})
# Assign proper column names
colnames(weighted_matrix) <- paste0("Scenario ", seq_along(w))
# Combine with dw
dw <- cbind(dw, weighted_matrix)
# long format for plotting:
dfl <- melt(
dw,
id.vars = 'new.ID',
measure.vars = c('raw', paste0('sce', 1:6)),
variable.name = 'scenario',
value.name = 'EF'
)
# long format for plotting:
dfl <- melt(
dw,
id.vars = 'new.ID',
measure.vars = c('raw', paste0('Scenario ', 1:6)),
variable.name = 'scenario',
value.name = 'EF'
)
