# times
df$time <- gsub("\\.", ":", df$time)
df[, time := {
x <- trimws(time)
x <- sub("^([0-9]{1,2}:[0-9]{2}).*$", "\\1", x)
x <- ifelse(grepl("^\\d{2}$", x),
paste0(x, ":00:00"), x)
x <- ifelse(grepl("^\\d{2}:\\d{1}$", x),
sub("^(\\d{2}):(\\d)$", "\\1:0\\2:00", x), x)
x <- ifelse(grepl("^\\d{2}:\\d{2}$", x),
paste0(x, ":00"), x)
x
}]
