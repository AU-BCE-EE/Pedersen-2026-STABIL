geom_line() +
facet_wrap(~ new.ID, scales = 'free_x') +
theme_bw() +
labs(x = 'Time after application (h)', y = 'Air temperature (°C)') +
theme(legend.position = 'bottom', legend.title = element_blank())
ggsave2x('../plots-meas/temp', height = 10, width = 10)
