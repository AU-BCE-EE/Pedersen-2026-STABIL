df <- df[!(new.ID == 'Trial 7' | new.ID == 'Trial 8' | new.ID == 'Trial 9')]
df[, form := fcase(
treat == "AD"   | treat == "PS",   "raw",
treat == "AD-L" | treat == "PS-L", "liquid",
treat == "AD-F" | treat == "PS-F", "solid"
)]
wide <- dcast(
df,
new.ID ~ form,
value.var = c("e.rel.130", "e.rel.130.sd"),
fun.aggregate = mean,
na.rm = TRUE
)
wide <- dcast(
df,
new.ID ~ form,
value.var = c("e.rel.130", "e.rel.130.sd"),
fun.aggregate = mean
)
wide <- dcast(
df,
new.ID ~ form,
value.var = c("e.rel.130", "e.rel.130.sd")
)
