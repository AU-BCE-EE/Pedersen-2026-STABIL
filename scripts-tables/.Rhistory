bottom <- (f331 | f332 | f333) +
plot_layout(guides = "collect") &
theme(
legend.position = "bottom",
legend.key.size = unit(0.4, "lines"),      # shrink legend keys
legend.spacing.y = unit(0.1, "lines")
) &
