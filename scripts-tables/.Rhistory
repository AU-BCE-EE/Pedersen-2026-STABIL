`2` =  'Trial 3',
`3` =  'Trial 5',
`4` =  'Trial 2',
`5` =  'Trial 4',
`6` =  'Trial 6',
`7` =  'Trial 7',
`8` =  'Trial 8',
`9` =  'Trial 9')
data_slurry[, new.ID := IDs[experiment]]
data_soil[, new.ID := IDs[experiment]]
rm(list=ls())
